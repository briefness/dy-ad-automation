# ============================================================
# 可灵 API 配置
# ============================================================
# 获取地址：https://app.klingai.com/cn/dev

# 【推荐】JWT 鉴权：填写 AccessKey + SecretKey（二选一）
KLING_ACCESS_KEY=your_access_key_here
KLING_SECRET_KEY=your_secret_key_here

# 【兼容】旧版 Bearer 鉴权：直接填 API Key（填写后优先使用）
KLING_API_KEY=your-api-key-kling

# 可选：API 地址（默认北京节点）
KLING_BASE_URL=https://api-beijing.klingai.com

# ============================================================
# 火山引擎 TTS 配置（可选，填写后启用豆包大模型语音合成 V3）
# API Key 获取：https://console.volcengine.com/speech/new/setting/apikeys
# ============================================================
# 未填写时自动降级到 macOS say（离线，免费）
VOLC_API_KEY=your_volc_api_key_here
# 可选：模型版本，默认 seed-tts-2.0（豆包语音合成大模型 2.0）
# 声音复刻音色请改为 seed-icl-2.0
# VOLC_RESOURCE_ID=seed-tts-2.0

# ============================================================
# LLM 文案生成配置（可选，填写后启用 AI 生成广告文案）
# ============================================================
# 未填写时走纯模板生成
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=your_llm_base_url_here
LLM_MODEL=your_llm_model_here

# ============================================================
# 日志级别（可选）
# ============================================================
# KLING_LOG_LEVEL=INFO
